\",\"children\":\"Join our outdoor community\"}]]}]]}],[\"$\",\"p\",null,{\"className\":\"text-sm md:col-span-3\",\"children\":[\"© \",2026,\". All rights reserved.\"]}]]}]}]\n9:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$Lf\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L10\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\na:[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"bg-white text-[#1a1a1a]\",\"children\":[[\"$\",\"section\",null,{\"className\":\"relative min-h-[620px] overflow-hidden\",\"children\":[[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/bobby-langin.jpg\",\"alt\":\"Langtown Racing Academy team\",\"fill\":true,\"priority\":true,\"sizes\":\"100vw\",\"className\":\"object-cover object-center\"}],[\"$\",\"div\",null,{\"className\":\"absolute inset-0 bg-black/35\"}],[\"$\",\"div\",null,{\"className\":\"relative mx-auto flex min-h-[620px] max-w-7xl items-center px-4 py-20 md:px-8\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-3xl text-white\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"text-4xl font-semibold leading-tight md:text-6xl\",\"children\":\"Empowering Outdoor Experiences Through Mountain Biking\"}],[\"$\",\"p\",null,{\"className\":\"mt-6 max-w-xl text-lg leading-relaxed\",\"children\":\"Meet Langtown Racing Academy and the riders building confidence, character, and racing skill on course.\"}]]}]}]]}],[\"$\",\"section\",null,{\"className\":\"mx-auto grid max-w-7xl gap-10 px-4 py-20 md:grid-cols-[0.8fr_1.2fr] md:px-8\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-[460px] overflow-hidden rounded-lg bg-[#dadce0]\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/bobby-langin.jpg\",\"alt\":\"Bobby Langin\",\"fill\":true,\"sizes\":\"(min-width: 768px) 40vw, 100vw\",\"className\":\"object-contain object-center\"}]}],[\"$\",\"div\",null,{\"className\":\"flex flex-col justify-center\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-4xl font-semibold md:text-6xl\",\"children\":\"Bobby Langin\"}],[\"$\",\"p\",null,{\"className\":\"mt-5 text-lg leading-relaxed text-[#56585e]\",\"children\":\"Bobby has an undeniable passion for two wheels. Growing up in a home with a backyard mini bike track and a father who raced BMX professionally, it was no surprise he started racing bicycles at just three years old and motorcycles by four. Racing motocross and various forms of bicycles gave Bobby the opportunity to travel across North America, competing against some of the best riders in the world. A true student of the sport, he is constantly expanding his knowledge to refine his training methods and techniques, both on and off the bike.\"}],[\"$\",\"div\",null,{\"className\":\"mt-8 rounded-lg bg-[#f7f7f7] p-6 space-y-3\",\"children\":[[\"$\",\"p\",\"Accomplishments: Husband and Father\",{\"className\":\"text-[#56585e]\",\"children\":\"Accomplishments: Husband and Father\"}],[\"$\",\"p\",\"Coaching: USA Cycling Coach Level 3, PMBIA Level 1 and NICA Level 3 Instructor\",{\"className\":\"text-[#56585e]\",\"children\":\"Coaching: USA Cycling Coach Level 3, PMBIA Level 1 and NICA Level 3 Instructor\"}],[\"$\",\"p\",\"Bicycle Racing Levels Achieved: Downhill - UCI Elite, Enduro - Pro, Cyclocross - UCI Elite, Cross Country - Cat 1\",{\"className\":\"text-[#56585e]\",\"children\":\"Bicycle Racing Levels Achieved: Downhill - UCI Elite, Enduro - Pro, Cyclocross - UCI Elite, Cross Country - Cat 1\"}]]}]]}]]}],[\"$\",\"section\",null,{\"className\":\"bg-[#f7f7f7]\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-7xl px-4 py-20 md:px-8\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-4xl font-semibold md:text-6xl\",\"children\":\"The Team\"}],[\"$\",\"div\",null,{\"className\":\"mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3\",\"children\":[[\"$\",\"article\",\"Beatrice Blackburn\",{\"className\":\"overflow-hidden rounded-lg bg-white shadow-sm\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-72 bg-[#dadce0]\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/bebe-blackburn.jpg\",\"alt\":\"Beatrice Blackburn\",\"fill\":true,\"sizes\":\"(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw\",\"className\":\"object-contain object-center\"}]}],[\"$\",\"div\",null,{\"className\":\"p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Beatrice Blackburn\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 leading-relaxed text-[#56585e]\",\"children\":\"I've been riding since I was 4 or 5 years old but started racing at 12. This will be my third year of racing. Until recently, I only competed in SoCal League XC races, but earlier this year, I began participating in other events. I placed on the podium in two of the three SoCal League races I entered and also earned podium finishes in both Rim Nordic XC races I competed in.\"}]]}]]}],\"$L11\",\"$L12\",\"$L13\",\"$L14\",\"$L15\",\"$L16\",\"$L17\",\"$L18\",\"$L19\",\"$L1a\",\"$L1b\",\"$L1c\",\"$L1d\"]}]]}]}],\"$L1e\",\"$L1f\"]}],null,\"$L20\"]}]\n21:[]\nb:\"$W21\"\nc:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L22\",null,{\"children\":\"$L23\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L24\",null,{\"children\":[\"$\",\"$25\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L26\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}]\ne:[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/018kj-1sceuuo.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n27:I[97367,[\"/_next/static/chunks/03b8nqb9rwvi~.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\"],\"OutletBoundary\"]\n11:[\"$\",\"article\",\"Cameron Scacheri\",{\"className\":\"overflow-hidden rounded-lg bg-white shadow-sm\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-72 bg-[#dadce0]\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/coaches/cam-scacheri.jpg\",\"alt\":\"Cameron Scacheri\",\"fill\":true,\"sizes\":\"(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw\",\"className\":\"object-contain object-center\"}]}],[\"$\",\"div\",null,{\"className\":\"p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Cameron Scacheri\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 leading-relaxed text-[#56585e]\",\"children\":\"I started racing cyclocross in Ohio at 12 years old, inspired by my love of bicycles and my dad, who is an avid cyclist. In my senior year, I moved to California and rediscovered my love for racing bikes. Transitioning from the flat terrain of Ohio to the incredible mountain bike trails in California reignited my competitive fire. I joined the Newbury Park mountain bike team placing 1st in the JV1 category and earning consistent top-10 finishes in JV2. I also ventured into enduro racing with Team Big Bear, where I podiumed in the beginner class. After graduating, in the fall of 2023, I began working with Bobby Langin, who has helped take my skills and training to the next level. Now, I'm riding six days a week, constantly pushing myself to improve. My passion for cycling is stronger than ever, and I don't see myself slowing down anytime soon.\"}]]}]]}]\n12:[\"$\",\"article\",\"Jeremy Rowell\",{\"className\":\"overflow-hidden rounded-lg bg-white shadow-sm\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-72 bg-[#dadce0]\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/jeremy-rowell.jpg\",\"alt\":\"Jeremy Rowell\",\"fill\":true,\"sizes\":\"(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw\",\"className\":\"object-contain object-center\"}]}],[\"$\",\"div\",null,{\"className\":\"p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Jeremy Rowell\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 leading-relaxed text-[#56585e]\",\"children\":\"Jeremy is a 17-year-old high school senior at Newbury Park High School and a racer for Langtown Racing Academy and the NPHS team. He has been riding for seven years and has no plans of stopping. This is his second year competing in SoCal Varsity and his third year racing in the U.S. National Championships for XCO.\"}]]}]]}]\n13:[\"$\",\"article\",\"Joe Morris\",{\"className\":\"overflow-hidden rounded-lg bg-white shadow-sm\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-72 bg-[#dadce0]\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/home/joe-and-mia.jpg\",\"alt\":\"Joe Morris\",\"fill\":true,\"sizes\":\"(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw\",\"className\":\"object-contain object-center\"}]}],[\"$\",\"div\",null,{\"className\":\"p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Joe Morris\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 leading-relaxed text-[#56585e]\",\"children\":\"He has been riding mountain bikes on and off for over 30 years but became more consistent in 2007. In 2018, he became a NICA coach for a high school cross-country racing team, a role he continued for the next five years. The following year, he competed in two local enduros, placing in the top five in both. He repeated these races in 2020 with the same top-five results. After the pandemic, he returned to the same enduro races in 2023, securing 2nd overall in the Team Big Bear Kenda Cup series in the Master 60+ class. Due to injury, he was only able to race twice in 2024, earning a 1st-place finish at a Team Big Bear Kenda Cup enduro and a 2nd-place finish at the California Enduro Series China Peak enduro. For the 2025 season, he plans to compete in all Team Big Bear Kenda Cup Enduro races and the majority of the California Enduro Series.\"}]]}]]}]\n14:[\"$\",\"article\",\"Jonny Franco\",{\"className\":\"overflow-hidden rounded-lg bg-white shadow-sm\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-72 bg-[#dadce0]\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/jonny.png\",\"alt\":\"Jonny Franco\",\"fill\":true,\"sizes\":\"(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw\",\"className\":\"object-contain object-center\"}]}],[\"$\",\"div\",null,{\"className\":\"p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Jonny Franco\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 leading-relaxed text-[#56585e]\",\"children\":\"I am originally from Israel but moved to the US in 2021. Living in the mountain community in Israel, the mountain bike has been a major part of my life. Moving to the American mtb scene was a harder transition than expected but after meeting the right people I was able to find my rhythm ultimately leading me to join Langtown Racing Academy. My coach says I may have too much energy. I can't help it, I love riding bikes! Always stoked to be on them, even if it's an interval day. I am looking forward to competing in 2025, building a healthy mind and body for racing and pushing myself further into this sport.\"}]]}]]}]\n15:[\"$\",\"article\",\"Josh Abugow\",{\"className\":\"overflow-hidden rounded-lg bg-white shadow-sm\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-72 bg-[#dadce0]\",\"children\":[\"$\",\"div\",null,{\"className\":\"h-full min-h-72 w-full bg-[#dadce0]\",\"aria-label\":\"Josh Abugow photo placeholder\"}]}],[\"$\",\"div\",null,{\"className\":\"p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Josh Abugow\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 leading-relaxed text-[#56585e]\",\"children\":\"Josh Abugow is a high school student at Royal High School, enrolled in Advanced Placement classes with a 4.87 GPA. Outside of school, he works as a host at a local Italian restaurant, though he is more often found doing what he loves most - riding bikes and exploring the outdoors. He plans to attend San Diego State University to pursue a degree in biopsychology while competing in bike races at both the collegiate and national levels.\"}]]}]]}]\n16:[\"$\",\"article\",\"Kaden Storey\",{\"className\":\"overflow-hidden rounded-lg bg-white shadow-sm\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-72 bg-[#dadce0]\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/kaden-storey.jpeg\",\"alt\":\"Kaden Storey\",\"fill\":true,\"sizes\":\"(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw\",\"className\":\"object-contain object-center\"}]}],[\"$\",\"div\",null,{\"className\":\"p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Kaden Storey\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 leading-relaxed text-[#56585e]\",\"children\":\"Kaden, now 15 years old, first started riding mountain bikes at the age of 5 or 6 when his grandfather introduced him to the sport and rode with him. From that point on, mountain biking remained a consistent part of his life, but he became more dedicated to it in 2020 during the pandemic, as many other sports shut down due to COVID-19. He initially raced Cross-Country in 6th grade, then competed in both Cross-Country and Enduro in 7th grade before fully transitioning to Enduro in 8th grade. More recently, he has been training with Bobby Langin, leading to significant improvements in both his riding skills and overall fitness. As he looks ahead to the upcoming season, Kaden is eager to compete with his new team in events such as the California Enduro Series.\"}]]}]]}]\n17:[\"$\",\"article\",\"Kyle Johnson\",{\"className\":\"overflow-hidden rounded-lg bg-white shadow-sm\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-72 bg-[#dadce0]\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/kyle-johnson-podium.jpeg\",\"alt\":\"Kyle Johnson\",\"fill\":true,\"sizes\":\"(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw\",\"className\":\"object-contain object-center\"}]}],[\"$\",\"div\",null,{\"className\":\"p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Kyle Johnson\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 leading-relaxed text-[#56585e]\",\"children\":\"Kyle is 16 and fell in love with mountain biking at 9 years old and racing at 10. I grew up riding in the Santa Cruz Mountains with my dad. It's been a huge part of my life and doing it with friends makes it even better. Joining the local team in Santa Cruz really elevated my riding; that's when I competed in my first race, the Sea Otter Classic. It set off my passion for racing my bike. A few years later, we moved to Southern California. I was unsure how it would affect my riding. Then I joined this team. Since then, I've seen massive improvements in my skills, fitness, and confidence on gnarly trails. That's not the only thing that improved, however, I raced many races in the California Enduro Series and did well there. The team atmosphere at the races is amazing! I plan to continue having fun on the trails with my friends, and looking forward to the races!\"}]]}]]}]\n18:[\"$\",\"article\",\"Matt Bradley\",{\"className\":\"overflow-hidden rounded-lg bg-white shadow-sm\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-72 bg-[#dadce0]\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/matt.jpg\",\"alt\":\"Matt Bradley\",\"fill\":true,\"sizes\":\"(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw\",\"className\":\"object-contain object-center\"}]}],[\"$\",\"div\",null,{\"className\":\"p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Matt Bradley\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 leading-relaxed text-[#56585e]\",\"children\":\"Matt is a father of three children, a husband to an incredible wife that supports his need to be active, a commercial property manager, a NICA coach, and amateur bicycle mechanic. When not riding bikes or working, Matt spends his time with his family; investing in their activities and sports.\"}]]}]]}]\n19:[\"$\",\"article\",\"Max Richardson\",{\"className\":\"overflow-hidden rounded-lg bg-white shadow-sm\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-72 bg-[#dadce0]\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/max.jpeg\",\"alt\":\"Max Richardson\",\"fill\":true,\"sizes\":\"(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw\",\"className\":\"object-contain object-center\"}]}],[\"$\",\"div\",null,{\"className\":\"p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Max Richardson\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 leading-relaxed text-[#56585e]\",\"children\":\"Max has always enjoyed cycling as a favorite pastime. Growing up, he primarily rode road bikes with his dad and BMX with neighborhood friends. His favorite aspect of the sport is the opportunity to explore new places and experience different scenery. In 2024, he began racing Enduro, which has allowed him to meet incredible people, discover amazing trails, and challenge his skills.\"}]]}]]}]\n1a:[\"$\",\"article\",\"Mia Morris\",{\"className\":\"overflow-hidden rounded-lg bg-white shadow-sm\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-72 bg-[#dadce0]\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/mia-morris.jpg\",\"alt\":\"Mia Morris\",\"fill\":true,\"sizes\":\"(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw\",\"className\":\"object-contain object-center\"}]}],[\"$\",\"div\",null,{\"className\":\"p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Mia Morris\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 leading-relaxed text-[#56585e]\",\"children\":\"Mia Morris is a 17-year-old high school senior from California who has spent her life embracing the state's diverse landscapes - beaches, mountains, deserts, and snow. From a young age, she found confidence and resilience through mountain biking, a sport that has reinforced her belief that women have a place in male-dominated spaces. She hopes to inspire other girls to find success in the mountain biking community, whether through racing or simply as a passion. For Mia, mountain biking is more than just a sport; it's a lifestyle that provides a sense of community and belonging. Family and friends play a significant role in her life, and she values the time spent with those who matter most, both on and off the bike. While her future path remains uncertain, one thing is clear - mountain biking will always be an integral part of her journey.\"}]]}]]}]\n1b:[\"$\",\"article\",\"Patti Felker-Breiner\",{\"className\":\"overflow-hidden rounded-lg bg-white shadow-sm\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-72 bg-[#dadce0]\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/patti-felker-breiner.jpg\",\"alt\":\"Patti Felker-Breiner\",\"fill\":true,\"sizes\":\"(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw\",\"className\":\"object-contain object-center\"}]}],[\"$\",\"div\",null,{\"className\":\"p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Patti Felker-Breiner\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 leading-relaxed text-[#56585e]\",\"children\":\"Coming Soon\"}]]}]]}]\n1c:[\"$\",\"article\",\"Sullivan Hartman\",{\"className\":\"overflow-hidden rounded-lg bg-white shadow-sm\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-72 bg-[#dadce0]\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/sullivan-hartman.jpg\",\"alt\":\"Sullivan Hartman\",\"fill\":true,\"sizes\":\"(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw\",\"className\":\"object-contain object-center\"}]}],[\"$\",\"div\",null,{\"className\":\"p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Sullivan Hartman\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 leading-relaxed text-[#56585e]\",\"children\":\"Sullivan is a 15-year-old from Thousand Oaks, California, who has been riding bikes for most of his life. What started as a fun way to explore the outdoors with friends turned into a passion for mountain biking, especially during the COVID-19 pandemic. What was once just an escape into nature soon became a lifestyle, with daily rides after online school helping to sharpen his skills. His racing journey began at age 11, though at the time, he was more focused on tackling the most challenging terrain in his area. In his first race, he crashed on the final stage and injured his arm but still managed to reach the podium. That experience ignited a love for racing - pushing his limits, charging downhill as fast as possible, and striving to be the fastest on the course.\"}]]}]]}]\n1d:[\"$\",\"article\",\"Tyler Lawson\",{\"className\":\"overflow-hidden rounded-lg bg-white shadow-sm\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-72 bg-[#dadce0]\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/tyler.jpeg\",\"alt\":\"Tyler Lawson\",\"fill\":true,\"sizes\":\"(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw\",\"className\":\"object-contain object-center\"}]}],[\"$\",\"div\",null,{\"className\":\"p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Tyler Lawson\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 leading-relaxed text-[#56585e]\",\"children\":\"Tyler is a 15-year-old mountain bike racer who began his cycling journey in BMX, competing for about four years before transitioning to mountain biking in November of last year. He joined the Newbury Park Mountain Bike Team and quickly found success in cross-country racing, earning a podium finish in every race during the season. More recently, he developed an interest in enduro racing and now aims to compete in both cross-country and enduro events throughout the season.\"}]]}]]}]\n1e:[\"$\",\"section\",null,{\"className\":\"mx-auto max-w-7xl px-4 py-20 md:px-8\",\"children\":[\"$\",\"div\",null,{\"className\":\"grid gap-12 md:grid-cols-[1fr_1fr]\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-4xl font-semibold md:text-6xl\",\"children\":\"The Langtown Legacy\"}],[\"$\",\"div\",null,{\"className\":\"mt-6 space-y-5 text-lg leading-relaxed text-[#56585e]\",\"children\":[[\"$\",\"p\",\"Langtown Racing started back in 1984 when Bobby Langin Sr bought a house with a backyard intended for a bicycle motocross practice track. What started as training quickly turned into friends gathering to battle on mini bikes. An annual event was born.\",{\"children\":\"Langtown Racing started back in 1984 when Bobby Langin Sr bought a house with a backyard intended for a bicycle motocross practice track. What started as training quickly turned into friends gathering to battle on mini bikes. An annual event was born.\"}],[\"$\",\"p\",\"Over time the event grew, attracting the attention of magazines, television and the stars of the sport. Despite the growing media attention Bobby Sr and his wife Linda opened their doors to hundreds each year shining on the community around them.\",{\"children\":\"Over time the event grew, attracting the attention of magazines, television and the stars of the sport. Despite the growing media attention Bobby Sr and his wife Linda opened their doors to hundreds each year shining on the community around them.\"}],[\"$\",\"p\",\"Spectators were never charged and any money donated went to the pro purse and charities. RAD and Langtown Racing Academy want to honor the legacy by fostering a spirit of community, promoting good character, trail stewardship and racing until our legs fall off.\",{\"children\":\"Spectators were never charged and any money donated went to the pro purse and charities. RAD and Langtown Racing Academy want to honor the legacy by fostering a spirit of community, promoting good character, trail stewardship and racing until our legs fall off.\"}]]}],[\"$\",\"a\",null,{\"href\":\"https://giv.li/90m43b\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"mt-8 inline-flex min-h-12 items-center rounded-[50px] bg-[#1a1a1a] px-8 text-sm font-semibold text-white transition-colors hover:bg-black\",\"children\":\"Donate\"}]]}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-2 gap-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative min-h-64 overflow-hidden rounded-lg\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/lt-vintage.jpg\",\"alt\":\"Vintage Langtown racing\",\"fill\":true,\"sizes\":\"(min-width: 768px) 25vw, 50vw\",\"className\":\"object-cover\"}]}],[\"$\",\"div\",null,{\"className\":\"relative min-h-64 overflow-hidden rounded-lg\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/lt-justina.jpg\",\"alt\":\"Langtown legacy racing\",\"fill\":true,\"sizes\":\"(min-width: 768px) 25vw, 50vw\",\"className\":\"object-cover\"}]}],[\"$\",\"div\",null,{\"className\":\"relative col-span-2 min-h-72 overflow-hidden rounded-lg\",\"children\":[\"$\",\"$L5\",null,{\"src\":\"/images/athletes/lt-turn2.jpg\",\"alt\":\"Langtown turn two\",\"fill\":true,\"sizes\":\"(min-width: 768px) 50vw, 100vw\",\"className\":\"object-cover\"}]}]]}]]}]}]\n1f:[\"$\",\"section\",null,{\"className\":\"bg-[#f7f7f7]\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto grid max-w-7xl gap-8 px-4 py-16 md:grid-cols-2 md:px-8\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-3xl font-semibold\",\"children\":\"Our Location\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 leading-relaxed text-[#56585e]\",\"children\":\"We serve the Conejo Valley and surrounding Tri-County areas, fostering positive mental health through mountain biking and outdoor recreation in the community.\"}]]}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-[#56585e]\",\"children\":[[\"$\",\"p\",null,{\"children\":[[\"$\",\"span\",null,{\"className\":\"font-semibold text-[#1a1a1a]\",\"children\":\"Address: \"}],\"936 Calle Tulipan, Thousand Oaks, CA 91360\"]}],[\"$\",\"p\",null,{\"children\":[[\"$\",\"span\",null,{\"className\":\"font-semibold text-[#1a1a1a]\",\"children\":\"Hours: \"}],\"Mon - Fri\"]}],[\"$\",\"$L4\",null,{\"href\":\"/support\",\"className\":\"inline-flex min-h-12 items-center rounded-[50px] border border-[#1a1a1a] px-8 text-sm font-semibold text-[#1a1a1a] transition-colors hover:bg-[#1a1a1a] hover:text-white\",\"children\":\"Contact Ride and Develop\"}]]}]]}]}]\n20:[\"$\",\"$L27\",null,{\"children\":[\"$\",\"$25\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@28\"}]}]\n23:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n29:I[27201,[\"/_next/static/chunks/03b8nqb9rwvi~.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\"],\"IconMark\"]\n26:[[\"$\",\"title\",\"0\",{\"children\":\"Empowering Outdoor Experiences Through Mountain Biking | Ride and Develop\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Ride and Develop, Inc. is a nonprofit dedicated to empowering individuals through mountain bike racing and outdoor recreation. We provide coaching, training, and financial support to foster personal growth and resilience in the Conejo Valley and surrounding areas.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"keywords\",\"content\":\"mountain bike racing,Langtown Racing Academy,outdoor recreation\"}],[\"$\",\"link\",\"3\",{\"rel\":\"canonical\",\"href\":\"https://radtrails.org/racing\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:title\",\"content\":\"Empowering Outdoor Experiences through Mountain Bike Racing | Ride and Develop\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:description\",\"content\":\"Rid